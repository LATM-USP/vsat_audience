---
import DOMPurify from "isomorphic-dompurify";

import type { PublishedStory } from "@domain/story/publish/types";

type Props = {
  story: PublishedStory;
};

const { story } = Astro.props as Props;

const serializedStory = DOMPurify.sanitize(
  JSON.stringify({ story })
    .replace(/</g, "\\u003C")
    .replace(/>/g, "\\u003E")
    .replace(/&/g, "\\u0026")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029"),
);
---

{/* Dump the entire story so that it's available on the client-side */}
<script set:html={`window.current = ${serializedStory}`} />

<script>
  import countLines from "@domain/story/publish/support/countLines";
  import {
    isHeadingBlock,
    isLinkBlock,
    isPlaintextBlock,
  } from "@domain/story/publish/support/isBlock";
  import openingPageFor from "@domain/story/publish/support/openingPage";
  import openingSceneFor from "@domain/story/publish/support/openingScene";
  import type { LinkTarget } from "@domain/story/publish/types";

  import changePage from "./changePage";
  import { EVENT_LINK_ACTIVATED } from "./linkActivated";
  import { isTitleCardScene, titleCardSceneFor } from "./titleCardSceneFor";
  import type { Current, RenderOptions } from "./types";

  import Pd4WebModule from "./audience/pd4web.js";
  //import "./audience/pd4web.threads.js";

  /**
   * The maximum width of the text (fiction) content.
   */
  const MAX_WIDTH = 6;

  /**
   * The y-position where the fiction starts.
   *
   * * the heading
   * * then the (plaintext) content
   * * then the links (exits), if any
   *
   * The `y` value for each of the above is relative to this value.
   */
  const FICTION_Y = 5;
  /**
   * How much to "bump" text forward off the background box so that it can be
   * read.
   *
   * If the text is flush with the background it introduces odd artifacts when
   * moving around in the scene so we bump (lift) it a little.
   */
  const FICTION_TEXT_Z = 0.25;

  // Panel right edge is at x = (MAX_WIDTH + 1) / 2 = 3.5; tray (width 1.0)
  // centred at 4.0 sits flush against that edge with no gap.
  const TRAY_X = 4.0;
  const TRAY_WIDTH = 1.0;

  const OPACITY = 0.75;

  const THEME = Object.freeze({
    color: {
      primary: {
        background: "#2C3E50",
        text: "#ECF0F1",
      },
      fiction: {
        background: "#E0E0E0",
        text: "#2C3E50",
      },
      link: {
        background: "#2C3E50",
        backgroundActive: "#3C5976",
        text: "#ECF0F1",
      },
      audio: {
        background: "#079C0F",
        backgroundActive: "#09C312",
        icon: "#ECF0F1",
      },
    },
  });

  // audience audio setup
  /*let Pd4Web: any = null;
  
  Pd4WebModule().then((Pd4WebModulePromise: any) => {
  Pd4Web = new Pd4WebModulePromise.Pd4Web();
  Pd4Web.openPatch("./audience/index.pd", { renderGui: false });

    document.addEventListener("click",() => {
        Pd4Web.init();
        console.log("Pd4Web initialized on user interaction");
        setTimeout(() => {
          Pd4Web.sendSymbol("NewPathTosnd1", current.scene.audio.id);
          Pd4Web.sendBang("pplaysnd1");
        }, 1000);
      }, { once: true },
    );

    //Pd4Web.onBangReceived("ended", (r) => {
    // logica aframe para tocar denovo
    //  Pd4Web.sendBang("pplaysnd1");
    //});

  });*/

  AFRAME.registerComponent("story", {
    init: function () {
      const openingScene = openingSceneFor(window.current.story);
      const openingPage = openingPageFor(openingScene);

      if (!!openingScene.audio) {
        const [titleCardScene, titleCardPage] = titleCardSceneFor(
          window.current.story.title,
          openingScene,
          openingPage.link,
        );
        window.current.scene = titleCardScene;
        window.current.page = titleCardPage;
      } else {
        window.current.scene = openingScene;
        window.current.page = openingPage;
      }

      this.render(window.current, { isSceneChange: false });
    },
    events: {
      [EVENT_LINK_ACTIVATED]: function (e: CustomEvent<LinkTarget>) {
        const link = e.detail;

        const change = changePage(window.current.story)(
          link,
          window.current.scene,
        );

        if (change) {
          window.current.page = change.toPage;

          if (change.toScene) {
            window.current.scene = change.toScene;
          }

          this.render(window.current, { isSceneChange: !!change.toScene });
        }
      },
    },
    render: function (current: Current, options: RenderOptions) {
      const sky = document.querySelector("a-sky");
      if (sky) {
        if (current.scene.image) {
          sky.setAttribute("src", `#image-${current.scene.image.id}`);
        } else {
          sky.removeAttribute("src");
        }
      }

      const existingSound = this.el.components.sound;
      if (existingSound?.isPlaying) {
        existingSound.stopSound();
      }
      if (current.scene.audio) {
        this.el.setAttribute(
          "sound",
          `src: #audio-${current.scene.audio.id}; 
          autoplay: true; 
          volume: 7;
          loop: true;
          positional: false`,
        );
      } else {
        this.el.removeAttribute("sound");
      }

      const fiction = document.getElementById("fiction");
      if (fiction) {
        removeAllChildNodes(fiction);

        if (isTitleCardScene(current.scene)) {
          const linkToOpeningPage =
            current.page.content.find(isLinkBlock)?.link || "";

          const titleCard = document.createElement("a-entity");
          titleCard.setAttribute(
            "title-card",
            `title: ${window.current.story.title}; link: ${linkToOpeningPage}`,
          );
          titleCard.setAttribute("position", "0 1 0");

          fiction.appendChild(titleCard);
        } else {
          const headingText =
            current.page.content.find(isHeadingBlock)?.text || "";
          const headingLineCount = countLines(headingText);
          const heading = (() => {
            const entity = document.createElement("a-entity");
            entity.setAttribute(
              "block-heading",
              `text: ${headingText}; lineCount: ${headingLineCount}`,
            );

            return entity;
          })();

          const [content, lineCount] = (() => {
            const text = current.page.content
              .filter(isPlaintextBlock)
              .map((block) => block.text)
              .join("\n\n");

            // we add one so that we always have at least 2 lines;
            // this gives the fiction some room to breathe.
            const lineCount = countLines(text) + 1;

            const entity = document.createElement("a-entity");
            entity.setAttribute(
              "block-plaintext",
              `text: ${text}; lineCount: ${lineCount}`,
            );

            return [entity, lineCount];
          })();

          const links = (() => {
            const linkBlocks = current.page.content.filter(isLinkBlock);

            const height = lineCount == 1 ? 1 : 1 + lineCount * 0.25;

            const elements = linkBlocks.map((block, index) => {
              const entity = document.createElement("a-entity");
              entity.setAttribute(
                "block-link",
                `text: ${block.text}; link: ${block.link}`,
              );

              const y = FICTION_Y - height - (index + 1);
              entity.setAttribute("position", `0 ${y} 0`);

              return entity;
            });

            return elements;
          })();

          links.forEach((link) => fiction.appendChild(link));
          fiction.appendChild(content);
          fiction.appendChild(heading);

          if (current.scene.audio) {
            const storyEl = document.querySelector("[story]");
            const isPlaying = options.isSceneChange
              ? true
              : (storyEl?.components?.sound?.isPlaying ?? true);

            const panel = document.createElement("a-entity");
            panel.setAttribute(
              "control-panel",
              `headingLineCount: ${headingLineCount}; isPlaying: ${isPlaying}`,
            );
            fiction.appendChild(panel);
          }
        }
      }
    },
  });

  AFRAME.registerComponent('rotation-reader', {
    init: function () {
      window.addEventListener('click', () => {
        const rotation = (this.el.object3D.rotation);
        console.log('Rotação atual:', rotation);
        /*if (Pd4Web) {
        // default do aframe e 10x10x10 (metros)
        // room metros
          Pd4Web.sendList("ori_rcv", [rotation.x, rotation.y, rotation.z]);
          console.log('Enviando rotação para Pd4Web:'); 
        }*/
      });
    }
  });

  AFRAME.registerComponent("block-heading", {
    schema: {
      text: { type: "string", default: "" },
      lineCount: { type: "number", default: 1 },
      fontSize: { type: "number", default: 0.25 },
    },
    init: function () {
      const y =
        this.data.lineCount == 1
          ? FICTION_Y
          : FICTION_Y + this.data.lineCount * 0.125;
      this.el.setAttribute("position", `0 ${y} 0`);

      const theText = ((el) => {
        el.setAttribute("value", this.data.text);
        el.setAttribute("font-size", this.data.fontSize);
        el.setAttribute("color", THEME.color.primary.text);
        el.setAttribute("max-width", MAX_WIDTH);
        el.setAttribute("anchor", "left");
        el.setAttribute("baseline", "top");

        const textY =
          this.data.lineCount == 1 ? 0 : this.data.lineCount * 0.155;
        el.setAttribute("position", `-${MAX_WIDTH / 2} ${textY} 0.5`);

        return el;
      })(document.createElement("a-troika-text"));

      const theBackground = ((el) => {
        el.setAttribute("color", THEME.color.primary.background);
        el.setAttribute("width", MAX_WIDTH + 1);
        el.setAttribute("depth", FICTION_TEXT_Z);
        el.setAttribute("opacity", OPACITY);

        const backgroundHeight =
          this.data.lineCount == 1 ? 1 : 1 + this.data.lineCount * 0.25;
        el.setAttribute("height", backgroundHeight);

        return el;
      })(document.createElement("a-box"));

      this.el.appendChild(theBackground);
      this.el.appendChild(theText);
    },
  });

  AFRAME.registerComponent("block-plaintext", {
    schema: {
      text: { type: "string", default: "" },
      lineCount: { type: "number", default: 1 },
    },
    init: function () {
      this.el.setAttribute("position", `0 ${FICTION_Y - 1} 0`);

      const theText = ((el) => {
        el.setAttribute("value", this.data.text);
        el.setAttribute("color", THEME.color.fiction.text);
        el.setAttribute("max-width", MAX_WIDTH);
        el.setAttribute("anchor", "left");
        el.setAttribute("baseline", "top");
        el.setAttribute("position", `-${MAX_WIDTH / 2} 0 0.5`);

        return el;
      })(document.createElement("a-troika-text"));

      const height =
        this.data.lineCount == 1 ? 1 : 1 + this.data.lineCount * 0.25;

      const theBackground = ((el) => {
        el.setAttribute("position", `0 -3 0`);
        el.setAttribute("color", THEME.color.fiction.background);
        el.setAttribute("width", MAX_WIDTH + 1);
        el.setAttribute("depth", FICTION_TEXT_Z);
        el.setAttribute("opacity", OPACITY);
        el.setAttribute("height", height);

        const y = this.data.lineCount === 1 ? 0 : this.data.lineCount * 0.125;
        el.setAttribute("position", `0 -${y} 0`);

        return el;
      })(document.createElement("a-box"));

      this.el.appendChild(theBackground);
      this.el.appendChild(theText);
    },
  });

  AFRAME.registerComponent("block-link", {
    schema: {
      text: { type: "string", default: "" },
      link: { type: "string", default: "" },
    },
    init: function () {
      const theText = document.createElement("a-troika-text");
      theText.setAttribute("value", this.data.text);
      theText.setAttribute("data-raycastable", "");
      theText.setAttribute("color", THEME.color.link.text);
      theText.setAttribute("max-width", MAX_WIDTH);
      theText.setAttribute("anchor", "left");
      theText.setAttribute("baseline", "top");
      theText.setAttribute("position", `-${MAX_WIDTH / 2} 0.1 0.5`);

      const theButton = document.createElement("a-box");
      theButton.setAttribute("width", MAX_WIDTH + 1);
      theButton.setAttribute("depth", FICTION_TEXT_Z);
      theButton.setAttribute("opacity", OPACITY);
      theButton.setAttribute("color", THEME.color.link.background);
      theButton.setAttribute(
        "event-set__mouseenter",
        `color: ${THEME.color.link.backgroundActive}`,
      );
      theButton.setAttribute(
        "event-set__mouseleave",
        `color: ${THEME.color.link.background}`,
      );

      this.el.appendChild(theButton);
      this.el.appendChild(theText);
    },
    events: {
      click: function () {
        this.el.emit(EVENT_LINK_ACTIVATED, this.data.link);
      },
    },
  });

  AFRAME.registerComponent("title-card", {
    schema: {
      title: { type: "string" },
      link: { type: "string" },
    },
    init: function () {
      const theHeading = (() => {
        const el = document.createElement("a-entity");
        el.setAttribute("block-heading", `text: ${this.data.title}`);
        return el;
      })();

      const theButton = (() => {
        const box = document.createElement("a-box");
        box.setAttribute("color", "#079C0F");
        box.setAttribute("width", 1.8);
        box.setAttribute("height", 1.5);
        box.setAttribute("depth", 0.3);
        box.setAttribute("data-raycastable", "");
        box.setAttribute("opacity", OPACITY);
        box.setAttribute(
          "animation",
          "property: color; from: #079C0F; to: #0DC414; easing: easeInOutSine; dir: alternate; loop: true; delay: 1000;",
        );

        const triangle = document.createElement("a-triangle");
        triangle.setAttribute("color", "#FFFFFF");
        triangle.setAttribute("rotation", "0 0 -90");
        triangle.setAttribute("position", "0.1 0 0.2");

        const container = document.createElement("a-entity");
        container.setAttribute("position", "-0.25 0.75 0.5");
        container.appendChild(box);
        container.appendChild(triangle);

        return container;
      })();

      this.el.appendChild(theHeading);
      this.el.appendChild(theButton);
    },
    events: {
      click: function () {
        this.el.emit(EVENT_LINK_ACTIVATED, this.data.link);
      },
    },
  });

  function removeAllChildNodes(parent: Node) {
    while (parent.firstChild) {
      parent.removeChild(parent.firstChild);
    }
  }

  AFRAME.registerComponent("play-pause-toggle", {
    schema: {
      isPlaying: { type: "boolean", default: true },
    },
    init: function () {
      const box = document.createElement("a-box");
      box.setAttribute("color", "#079C0F");
      box.setAttribute("width", 0.9);
      box.setAttribute("height", 0.9);
      box.setAttribute("depth", 0.3);
      box.setAttribute("data-raycastable", "");
      box.setAttribute("opacity", OPACITY);

      box.setAttribute(
        "event-set__mouseenter",
        `color: ${THEME.color.audio.backgroundActive}`,
      );
      box.setAttribute(
        "event-set__mouseleave",
        `color: ${THEME.color.audio.background}`,
      );

      // a play button ▶️
      const playIcon = document.createElement("a-triangle");
      playIcon.setAttribute("color", `${THEME.color.audio.icon}`);
      playIcon.setAttribute("rotation", "0 0 -90");
      playIcon.setAttribute("position", "0.05 0 0.2");
      playIcon.setAttribute("scale", "0.6 0.6 0.6");

      // a pause button ⏸️
      const pauseIcon = document.createElement("a-entity");
      const barL = document.createElement("a-box");
      barL.setAttribute("color", `${THEME.color.audio.icon}`);
      barL.setAttribute("width", 0.14);
      barL.setAttribute("height", 0.48);
      barL.setAttribute("depth", 0.05);
      barL.setAttribute("position", "-0.14 0 0.2");
      const barR = document.createElement("a-box");
      barR.setAttribute("color", `${THEME.color.audio.icon}`);
      barR.setAttribute("width", 0.14);
      barR.setAttribute("height", 0.48);
      barR.setAttribute("depth", 0.05);
      barR.setAttribute("position", "0.14 0 0.2");
      pauseIcon.appendChild(barL);
      pauseIcon.appendChild(barR);

      this.playIcon = playIcon;
      this.pauseIcon = pauseIcon;

      this.el.appendChild(box);
      this.el.appendChild(playIcon);
      this.el.appendChild(pauseIcon);

      this._syncIcons();

      const storyEl = document.querySelector("[story]");
      if (storyEl) {
        this._onSoundEnded = () => {
          this.el.setAttribute("play-pause-toggle", "isPlaying", false);
        };
        storyEl.addEventListener("sound-ended", this._onSoundEnded);
      }
    },
    remove: function () {
      const storyEl = document.querySelector("[story]");
      if (storyEl && this._onSoundEnded) {
        storyEl.removeEventListener("sound-ended", this._onSoundEnded);
      }
    },
    update: function () {
      if (this.playIcon) {
        this._syncIcons();
      }
    },
    _syncIcons: function () {
      this.playIcon.setAttribute("visible", String(!this.data.isPlaying));
      this.pauseIcon.setAttribute("visible", String(this.data.isPlaying));
    },
    events: {
      click: function () {
        const storyEl = document.querySelector("[story]");
        const sound = storyEl?.components?.sound;
        if (!sound) {
          return;
        }

        if (sound.isPlaying) {
          sound.pauseSound();
          this.el.setAttribute("play-pause-toggle", "isPlaying", false);
        } else {
          sound.playSound();
          this.el.setAttribute("play-pause-toggle", "isPlaying", true);
        }
      },
    },
  });

  AFRAME.registerComponent("control-panel", {
    schema: {
      headingLineCount: { type: "number", default: 1 },
      isPlaying: { type: "boolean", default: true },
    },
    init: function () {
      const headingY =
        this.data.headingLineCount === 1
          ? FICTION_Y
          : FICTION_Y + this.data.headingLineCount * 0.125;

      this.el.setAttribute("position", `${TRAY_X} ${headingY} 0`);

      const trayHeight =
        this.data.headingLineCount === 1
          ? 1
          : 1 + this.data.headingLineCount * 0.25;

      const trayBackground = document.createElement("a-box");
      trayBackground.setAttribute("color", THEME.color.primary.background);
      trayBackground.setAttribute("width", TRAY_WIDTH);
      trayBackground.setAttribute("height", trayHeight);
      trayBackground.setAttribute("depth", FICTION_TEXT_Z);
      trayBackground.setAttribute("opacity", OPACITY);

      const toggle = document.createElement("a-entity");
      toggle.setAttribute("play-pause-toggle", `isPlaying: ${this.data.isPlaying}`);

      this.el.appendChild(trayBackground);
      this.el.appendChild(toggle);
    },
  });
</script>
